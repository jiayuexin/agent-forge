{
  "name": "agentforge",
  "private": true,
  "version": "0.0.0",
  "description": "AI Agent Framework — 从描述生成可运行的 Agent",
  "scripts": {
    "build": "pnpm -r --stream run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/*/src --ext .ts",
    "typecheck": "pnpm -r --stream run typecheck",
    "clean": "pnpm -r --stream run clean"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "tsup": "^8.1.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "prettier": "^3.3.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.6.12"
}
