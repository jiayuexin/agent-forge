/**
 * Tool definitions for the <%= agentRole %> agent.
 * Generated by @agentforge/core
 */

import { ToolDefinition } from './types';

export const TOOLS: ToolDefinition[] = [<% tools.forEach(function(tool, i) { %>
  {
    name: '<%= tool.name %>',
    description: '<%= tool.description.replace(/'/g, "\\'") %>',
    parameters: <%- JSON.stringify(tool.parameters, null, 4) %>,
  }<%= i < tools.length - 1 ? ',' : '' %><% }); %>
];
